// ourfund Prisma schema (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  passwordHash      String?
  googleId          String?  @unique
  name              String
  phone             String?
  pronouns          String?
  initials          String
  personalCurrency  String   @default("USD")
  budgetMode        String   @default("personal")
  reportPeriod      String   @default("Month")
  notificationPrefs Json     @default("{\"Category at 80%\":true,\"Category over budget\":true,\"Large transaction\":false,\"New member expense\":true,\"Transfer requests\":true,\"Goal contributions\":false,\"Daily digest\":true,\"Weekly report\":true,\"Bill reminders\":true}")
  historyFilters    Json     @default("{\"kind\":\"All\",\"member\":\"Anyone\",\"categories\":[],\"sort\":\"Newest\",\"minUsd\":0,\"maxUsd\":5000}")
  passcode          String?
  faceIdEnabled     Boolean  @default(true)
  compactMoneyMode  Boolean  @default(false)
  passwordResetTokenHash      String?
  passwordResetTokenExpiresAt DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  householdMembers FamilyMember[]
  notifications    AppNotification[]
}

model Household {
  id             String   @id @default(uuid())
  name           String
  inviteCode     String   @unique
  familyCurrency String   @default("UZS")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  members         FamilyMember[]
  wallets         WalletAccount[]
  categories      BudgetCategory[]
  transactions    Transaction[]
  goals           Goal[]
  linkedBanks     LinkedBank[]
  scheduleItems   ScheduleItem[]
  loanEntries     LoanEntry[]
  trackedProducts TrackedProduct[]
  receiptScans    ReceiptScan[]
}

model FamilyMember {
  id           String   @id @default(uuid())
  userId       String?
  householdId  String
  name         String
  email        String?
  role         String // "Admin" | "Adult" | "Teen" | "Kid"
  initials     String
  age          Int?
  allowanceUsd Float?
  allowanceDay String?
  allowanceOn  Boolean  @default(false)
  permissions  Json // Record<string, boolean>
  createdAt    DateTime @default(now())

  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model WalletAccount {
  id                 String   @id @default(uuid())
  householdId        String
  label              String
  sub                String
  type               String // "shared" | "private" | "connected"
  currency           String
  members            Json // string[] (family member IDs)
  color              String
  startingBalanceUsd Float    @default(0)
  createdAt          DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model BudgetCategory {
  id          String   @id @default(uuid())
  householdId String
  label       String
  limitUsd    Float
  color       String
  icon        String
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model Transaction {
  id          String   @id @default(uuid())
  householdId String
  name        String
  who         String
  usd         Float
  category    String
  wallet      String
  date        String
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model Goal {
  id           String   @id @default(uuid())
  householdId  String
  title        String
  targetUsd    Float
  savedUsd     Float
  targetDate   String
  icon         String
  color        String
  contributors Json // string[]
  history      Json // Goal history array
  createdAt    DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model LinkedBank {
  id          String   @id @default(uuid())
  householdId String
  name        String
  connectedAt String
  accounts    Json // Account array
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model ScheduleItem {
  id          String   @id @default(uuid())
  householdId String
  label       String
  every       String
  amountUsd   Float
  color       String
  type        String // "income" | "subscription"
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model LoanEntry {
  id                   String   @id @default(uuid())
  householdId          String
  ownerMemberId        String   @default("")
  counterpartyMemberId String?
  counterpartyName     String
  note                 String
  due                  String
  amountUsd            Float
  paidAmountUsd        Float    @default(0)
  direction            String // "lent" | "borrowed"
  status               String // "pending" | "paid" | "overdue"
  createdAt            DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model TrackedProduct {
  id           String   @id @default(uuid())
  householdId  String
  name         String
  store        String
  category     String
  amountUsd    Float
  quantity     Float    @default(1)
  unitPriceUsd Float?
  purchasedAt  String
  source       String   @default("manual")
  createdAt    DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model ReceiptScan {
  id          String   @id @default(uuid())
  householdId String
  storeName   String
  purchasedAt String
  currency    String
  totalUsd    Float
  items       Json
  rawText     String?
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model AppNotification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  desc      String
  time      String
  group     String
  tone      String
  read      Boolean  @default(false)
  screen    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
